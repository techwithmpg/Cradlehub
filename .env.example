APP_URL=https://www.cradlewellnessliving.com
NEXT_PUBLIC_APP_URL=https://www.cradlewellnessliving.com

# Supabase application runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Google Sign-In
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Supabase database tooling - never expose through NEXT_PUBLIC_*
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_DB_PASSWORD=your-rotated-database-password
SUPABASE_DB_POOLER_URL=postgresql://user:password@host:6543/postgres?sslmode=require
