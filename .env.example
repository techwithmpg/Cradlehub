APP_URL=https://www.cradlewellnessliving.com
NEXT_PUBLIC_APP_URL=https://www.cradlewellnessliving.com

# Supabase application runtime
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Server-only attendance device credential pepper. Required in production; never prefix with NEXT_PUBLIC_.
ATTENDANCE_DEVICE_SECRET=

# Attendance launch gates. Enforcement defaults to disabled when unset.
NEXT_PUBLIC_ATTENDANCE_SCANNING_ENABLED=true
NEXT_PUBLIC_ATTENDANCE_ENFORCEMENT_ENABLED=false
# Server-only operational attestation after all four pg_cron jobs are verified.
ATTENDANCE_CLOSING_AUTOMATION_VERIFIED=false

# Retained workspace rollout: off | crm | all. CRM-first is the safe default.
NEXT_PUBLIC_RETAINED_WORKSPACES=crm

# Opt-in browser Web Push. Generate once with: pnpm exec web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:operations@example.com

# AI Coach remains hidden unless both values are valid and the current role is allowed.
ANTHROPIC_API_KEY=
AGENT_COACH_WORKSPACES=

# Google Sign-In
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Supabase database tooling - never expose through NEXT_PUBLIC_*
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_DB_PASSWORD=your-rotated-database-password
SUPABASE_DB_POOLER_URL=postgresql://user:password@host:6543/postgres?sslmode=require
