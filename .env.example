# Supabase — get these from dashboard.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
# Production example: NEXT_PUBLIC_APP_URL=https://cradlewellnessliving.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEV_ALLOW_ALL_MODULES=true

# Google Maps — browser keys for Places Autocomplete and Map rendering
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps — server-side key (Geocoding, Routes API)
GOOGLE_MAPS_SERVER_API_KEY=

# Staff Onboarding
STAFF_ONBOARDING_ENABLED=true
STAFF_ONBOARDING_ACCESS_CODE=

# AI Coach Agent
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Comma-separated list of workspaces that show the AI coach (e.g. crm,owner,manager,staff-portal)
AGENT_COACH_WORKSPACES=crm

# Follow-Up Agent Cron (Vercel Cron Jobs)
# Vercel injects this into the Authorization header for cron requests.
CRON_SECRET=
BRANCH_TIMEZONE=Asia/Manila
